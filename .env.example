# Service dependencies
DB_HOST=db
DB_PORT=5432
DB_USER=mastodon
DB_NAME=mastodon_production
DB_PASS=your_db_password_here

REDIS_HOST=redis
REDIS_PORT=6379

# Federation
LOCAL_DOMAIN=yourdomain.com
ALTERNATE_DOMAINS=localhost,127.0.0.1

# Application secrets (Generate these using: docker run --rm -it --entrypoint /bin/bash lscr.io/linuxserver/mastodon:latest generate-secret)
SECRET_KEY_BASE=your_secret_key_base_here
OTP_SECRET=your_otp_secret_here

# VAPID keys (Generate these using: docker run --rm -it --entrypoint /bin/bash lscr.io/linuxserver/mastodon:latest generate-vapid)
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Active Record Encryption
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=your_deterministic_key_here
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=your_derivation_salt_here
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=your_primary_key_here

# System configuration
PUID=1000
PGID=1000
TZ=Etc/UTC

# Mastodon API Credentials
ACCESS_TOKEN=
